{
  "name": "@acprotocol/server",
  "version": "2.0.1",
  "description": "ACP Reference Server — a minimal TypeScript server implementing the Agent Control Protocol",
  "license": "Apache-2.0",
  "author": "Primoia Technologies (https://primoia.ai)",
  "repository": {
    "type": "git",
    "url": "https://github.com/agent-control-protocol/acp-server.git"
  },
  "homepage": "https://acp-protocol.org",
  "bugs": {
    "url": "https://github.com/agent-control-protocol/acp-server/issues"
  },
  "keywords": [
    "acp",
    "agent-control-protocol",
    "ai-agent",
    "ui-automation",
    "websocket",
    "openai",
    "protocol",
    "reference-server"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "bin": {
    "acp-server": "./dist/cli.js"
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli.ts",
    "start": "node dist/cli.js",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "dependencies": {
    "openai": "^6.33.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "@types/ws": "^8.5.13",
    "@vitest/coverage-v8": "^3.0.0",
    "ajv": "^8.17.1",
    "ajv-formats": "^3.0.1",
    "prettier": "^3.8.1",
    "tsup": "^8.3.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^3.0.0"
  },
  "engines": {
    "node": ">=18"
  }
}
